# NORA Web — Environment Variables

# Backend API base URL
NEXT_PUBLIC_API_URL=/api
BACKEND_URL=http://localhost:4001
# Cache management — secret to authorize POST /api/revalidate from BE.
# - 64 hex chars. Generate with: openssl rand -hex 32
# - Must match REVALIDATE_SECRET on BE `.env`.
REVALIDATE_SECRET=
